<UserControl x:Class="HeroArena.Views.CombatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HeroArena.ViewModels">

    <UserControl.DataContext>
        <vm:CombatViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource PrimaryBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Choisir votre héros : " Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding AvailableHeroes}"
          SelectedItem="{Binding SelectedHero}"
          Width="200"
          Background="#0f3460"
          Foreground="White"
          BorderBrush="{StaticResource AccentBrush}"
          Margin="0,0,10,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" 
                       Foreground="Black" 
                       Padding="4,2"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Lancer le combat"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding StartCombatCommand}"/>
            <TextBlock Text="{Binding PlayerScore, StringFormat='Score : {0}'}"
                       Foreground="Gold" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10"
              Visibility="{Binding PlayerHero, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding PlayerHero.Name}" Foreground="{StaticResource TextBrush}"
                           FontWeight="Bold" Margin="0,0,0,3"/>
                <ProgressBar Value="{Binding PlayerHpPercent, Mode=OneWay}" Maximum="100" Height="20"
                            Background="#333" Foreground="LimeGreen"/>
                <TextBlock Text="{Binding PlayerCurrentHp, StringFormat=' {0} HP'}"
                           Foreground="{StaticResource TextBrush}" FontSize="12"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="VS" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock Text="{Binding EnemyHero.Name}" Foreground="{StaticResource TextBrush}"
                           FontWeight="Bold" Margin="0,0,0,3" HorizontalAlignment="Right"/>
                <ProgressBar Value="{Binding EnemyHpPercent, Mode=OneWay}" Maximum="100" Height="20"
                            Background="#333" Foreground="OrangeRed"/>
                <TextBlock Text="{Binding EnemyCurrentHp, StringFormat=' {0} HP'}"
                           Foreground="{StaticResource TextBrush}" FontSize="12"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Tes sorts :" Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding PlayerSpells}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,6"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding DataContext.UseSpellCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Damage, StringFormat=' {0} dmg'}" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Border Grid.Column="1" Background="{StaticResource SecondaryBrush}"
                    Margin="10,0,0,0" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding CombatLog}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{Binding ResultMessage}" FontSize="18" FontWeight="Bold"
                       Foreground="Gold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="Nouveau combat"
                    Style="{StaticResource PrimaryButton}"
                    Background="#0f3460"
                    Command="{Binding NewCombatCommand}"
                    Visibility="{Binding IsCombatOver, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>