<Window x:Class="HeroArena.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HeroArena.ViewModels"
        Title="Hero Arena - Connexion"
        Width="420" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBrush}">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="HERO ARENA" 
                       FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Connexion" FontSize="16"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Nom d'utilisateur" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5"/>
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,20"/>

            <TextBlock Text="Mot de passe" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource DarkPasswordBox}"
                         Margin="0,0,0,20"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="OrangeRed" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,0,0,15"
                       TextWrapping="Wrap"/>

            <Button Content="Se connecter"
            Style="{StaticResource PrimaryButton}"
            Click="LoginButton_Click"
            Margin="0,0,0,10"/>

            <Button Content="Paramètres BDD"
                    Style="{StaticResource PrimaryButton}"
                    Background="#0f3460"
                    Command="{Binding OpenSettingsCommand}"/>

            <Button Content="Créer un compte"
                    Style="{StaticResource PrimaryButton}"
                    Background="#0f3460"
                    Click="RegisterButton_Click"
                    Margin="0,10,0,0"/>

        </StackPanel>
    </Grid>
</Window>