<UserControl x:Class="HeroArena.Views.SpellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HeroArena.ViewModels">

    <UserControl.DataContext>
        <vm:SpellViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource PrimaryBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Filtrer par héros : " Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding Heroes}"
                      SelectedItem="{Binding SelectedHeroFilter}"
                      DisplayMemberPath="Name"
                      Width="200" Background="#0f3460"
                      Foreground="{StaticResource TextBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding FilteredSpells}"
                     SelectedItem="{Binding SelectedSpell}"
                     Background="{StaticResource SecondaryBrush}"
                     Foreground="{StaticResource TextBrush}" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="8,5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="1" Background="{StaticResource SecondaryBrush}" Margin="10,0,0,0" Padding="20">
                <StackPanel Visibility="{Binding SelectedSpell, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="{Binding SelectedSpell.Name}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>
                    <TextBlock Text="{Binding SelectedSpell.Damage, StringFormat='Dégâts : {0}'}"
                               Foreground="{StaticResource TextBrush}" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding SelectedSpell.Description}"
                               Foreground="{StaticResource TextBrush}" FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>